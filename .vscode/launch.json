{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug full stack (Server + Client)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",          // or "bun run dev" / "pnpm dev" / "yarn dev"
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Next.js: Server only (attach to middleware)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Debug Next.js Full (Server + Browser)",
      "configurations": ["Next.js: debug full stack (Server + Client)"]
    }
  ]
}